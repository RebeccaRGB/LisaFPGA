#startgroup
create_pblock {CLKAG_DOTCK_ungated}
add_cells_to_pblock [get_pblocks  {CLKAG_DOTCK_ungated}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=DOTCK_bufg} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="DOTCK_ungated"}]]]
resize_pblock [get_pblocks {CLKAG_DOTCK_ungated}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1}
#endgroup

# Clock net "DOTCK" driven by instance "DOTCK_bufg" located at site "BUFGCTRL_X0Y19"
#startgroup
create_pblock {CLKAG_DOTCK}
add_cells_to_pblock [get_pblocks  {CLKAG_DOTCK}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="DOTCK"}]]]
resize_pblock [get_pblocks {CLKAG_DOTCK}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2}
#endgroup

# Clock net "C5M" driven by instance "C5M_bufg" located at site "BUFGCTRL_X0Y3"
#startgroup
create_pblock {CLKAG_C5M}
add_cells_to_pblock [get_pblocks  {CLKAG_C5M}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="C5M"}]]]
resize_pblock [get_pblocks {CLKAG_C5M}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2}
#endgroup

# Clock net "C16M" driven by instance "C16M_bufg" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_C16M}
add_cells_to_pblock [get_pblocks  {CLKAG_C16M}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="C16M"}]]]
resize_pblock [get_pblocks {CLKAG_C16M}] -add {CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2}
#endgroup
